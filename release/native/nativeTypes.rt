
a~~: U8 = 10
println(type(10+10)) # UInt
println(type(a)) # UInt
println(type(a-1)) # UInt т.к. не ушел ниже своего типа данных
println(type(a-11)) # Изменение внутреннего типа на Int
println(stype(a)) # U8
a = -10 # Работает т.к. мы указали модификатор ~~ (полная мутабельность)
println(type(a)) # Int
println(stype(a)) # I8